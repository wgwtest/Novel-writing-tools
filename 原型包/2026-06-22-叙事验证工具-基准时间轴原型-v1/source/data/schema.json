{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/novel-writing-tools/narrative-timeline.schema.json",
  "title": "叙事验证工具基准时间轴数据",
  "type": "object",
  "required": ["timelineConfig", "chapters", "characters", "tracks", "events"],
  "additionalProperties": true,
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "source": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "timelineConfig": {
      "type": "object",
      "required": ["defaultStart", "defaultEnd"],
      "additionalProperties": false,
      "properties": {
        "defaultStart": { "type": "string" },
        "defaultEnd": { "type": "string" }
      }
    },
    "chapters": {
      "type": "array",
      "items": { "$ref": "#/$defs/chapter" }
    },
    "characters": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/character" }
    },
    "tracks": {
      "type": "array",
      "items": { "$ref": "#/$defs/track" }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "chapter": {
      "type": "object",
      "required": ["id", "title", "startAt", "endAt", "input", "inside", "output"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "startAt": { "type": "string" },
        "endAt": { "type": "string" },
        "input": { "type": "string" },
        "inside": { "type": "string" },
        "output": { "type": "string" }
      }
    },
    "character": {
      "type": "object",
      "required": ["name", "short", "color", "soft"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "short": { "type": "string" },
        "color": { "type": "string" },
        "soft": { "type": "string" }
      }
    },
    "track": {
      "type": "object",
      "required": ["id", "name", "sub", "expanded", "characters"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sub": { "type": "string" },
        "expanded": { "type": "boolean" },
        "characters": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "event": {
      "type": "object",
      "required": ["id", "kind", "track", "startAt", "endAt", "title", "code", "tone", "input", "output", "risk"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["story", "character"] },
        "track": { "type": "string" },
        "character": { "type": "string" },
        "startAt": { "type": "string" },
        "endAt": { "type": "string" },
        "title": { "type": "string" },
        "code": { "type": "string" },
        "tone": { "type": "string" },
        "input": { "type": "string" },
        "output": { "type": "string" },
        "risk": { "type": "string" },
        "visibility": { "enum": ["explicit", "background"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "character" } },
            "required": ["kind"]
          },
          "then": {
            "required": ["character"]
          }
        }
      ]
    }
  }
}
